import requests
from bs4 import BeautifulSoup

# Pergunta ao usuário qual é o nome que deve ser procurado na música
nome = input('Qual é o seu nome? ')

# Faz uma busca no Google por músicas que contêm o nome digitado pelo usuário
url = 'https://www.google.com/search?q={}+música'.format(nome)
response = requests.get(url)

# Extrai os links das músicas encontradas na busca do Google
soup = BeautifulSoup(response.text, 'html.parser')
links = soup.find_all('a')
music_links = [link.get('href') for link in links if 'youtube' in link.get('href')]

# Exibe o link da primeira música encontrada
if len(music_links) > 0:
    print('Acesse o link abaixo para ouvir uma música que contém o seu nome:')
    print('https://google.com' + music_links[0])
else:
    print('Não foi possível encontrar uma música que contém o seu nome.')
